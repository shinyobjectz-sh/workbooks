{
  "id": "https://workbooks.sh/",
  "name": "Workbooks",
  "short_name": "Workbooks",
  "description": "Open and edit single-file workbook applications. The file is the database — your work lives in the .html file.",
  "start_url": "https://workbooks.sh/",
  "scope": "https://workbooks.sh/",
  "display": "standalone",
  "background_color": "#09090b",
  "theme_color": "#09090b",
  "orientation": "any",
  "lang": "en",
  "icons": [
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "/screenshot-wide.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Workbooks landing on desktop"
    },
    {
      "src": "/screenshot-narrow.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Workbooks landing on mobile"
    }
  ],
  "file_handlers": [
    {
      "action": "/launch",
      "accept": {
        "text/html": [".workbook.html"]
      },
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "categories": ["productivity", "utilities"]
}
